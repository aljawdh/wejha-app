# ============================================================
# وِجهة — Environment Variables
# 1. Copy this file to .env.local
# 2. Fill in your Supabase credentials from:
#    https://supabase.com/dashboard → Project Settings → API
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# App
NEXT_PUBLIC_APP_NAME=وِجهة
NEXT_PUBLIC_APP_URL=https://wejha.qa

# WhatsApp OTP (Twilio or Meta Business API)
WHATSAPP_API_URL=https://api.twilio.com/...
WHATSAPP_TOKEN=YOUR_TOKEN_HERE

# Optional: Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=YOUR_MAPS_KEY_HERE
